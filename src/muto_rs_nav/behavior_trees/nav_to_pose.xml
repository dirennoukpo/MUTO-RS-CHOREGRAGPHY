<?xml version="1.0" encoding="UTF-8"?>
<root main_tree_to_execute="MainTree">
  <BehaviorTree ID="MainTree">
    <!--
      Formation choreography BT for MUTO RS follower robots.

      Blackboard variables (injected via nav2_params.yaml or action goal):
        robot_id          : this robot's ID string
        leader_robot_id   : leader robot's ID string
        min_battery_level : battery threshold (float, e.g. 20.0)
        offset_x / offset_y / offset_z : formation offset in metres (double)

      Execution flow (per BT tick):
        1. CheckBatteryLevel  — re-evaluated every tick (ReactiveSequence)
        2. RateController 1Hz — every second:
             a. GetPosition       -> subscribes /robot{leader_id}/pose (PoseStamped)
             b. SetNewPosition    -> leader_pose + offset -> {target_pose} (PoseStamped)
             c. ComputePathToPose -> calls Nav2 planner; writes {path}
        3. FollowPath         — follows {path}; restarted automatically when path changes

      Recovery (up to 6 retries): Wait 2 s then clear global + local costmaps.
    -->
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">

      <ReactiveSequence name="FormationControl">

        <!-- Battery guard: aborts the whole sequence if battery too low -->
        <CheckBatteryLevel
          robot_id="{robot_id}"
          min_battery_level="{min_battery_level}"
          battery_level="{battery_level}"/>

        <!--
          Replan at 1 Hz.
          When RateController fires, ComputePathToPose returns RUNNING ->
          ReactiveSequence halts FollowPath (cancels the action server goal) ->
          once the new path is ready, FollowPath restarts with the updated path.
          Between replan bursts RateController returns SUCCESS immediately,
          leaving FollowPath undisturbed.
        -->
        <RateController hz="1.0">
          <Sequence name="UpdateFormationGoal">
            <GetPosition
              robot_id="{leader_robot_id}"
              position="{ref_position}"/>
            <SetNewPosition
              ref_position="{ref_position}"
              offset_x="{offset_x}"
              offset_y="{offset_y}"
              offset_z="{offset_z}"
              position="{target_pose}"/>
            <ComputePathToPose
              goal="{target_pose}"
              path="{path}"
              planner_id="GridBased"/>
          </Sequence>
        </RateController>

        <!-- Follow the last computed path continuously -->
        <FollowPath
          path="{path}"
          controller_id="FollowPath"/>

      </ReactiveSequence>

      <!-- Executed whenever FormationControl returns FAILURE -->
      <Sequence name="RecoveryActions">
        <Wait wait_duration="2"/>
        <ClearEntireCostmap
          name="ClearGlobalCostmap"
          server_name="global_costmap/clear_entirely_global_costmap"
          server_timeout="10"/>
        <ClearEntireCostmap
          name="ClearLocalCostmap"
          server_name="local_costmap/clear_entirely_local_costmap"
          server_timeout="10"/>
      </Sequence>

    </RecoveryNode>
  </BehaviorTree>
</root>
